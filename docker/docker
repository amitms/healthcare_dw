# Use Python base image for ETL + Airflow
FROM python:3.12-slim

# Install Oracle Instant Client dependencies
RUN apt-get update && apt-get install -y unzip libaio1 wget && rm -rf /var/lib/apt/lists/*

# Set Oracle Instant Client version
ENV ORACLE_INSTANT_CLIENT_VERSION=21.9.0.0.0
ENV ORACLE_HOME=/opt/oracle/instantclient_${ORACLE_INSTANT_CLIENT_VERSION}

# Download and install Oracle Instant Client
RUN mkdir -p $ORACLE_HOME && \
    wget https://download.oracle.com/otn_software/linux/instantclient/219000/instantclient-basiclite-linux.x64-${ORACLE_INSTANT_CLIENT_VERSION}.zip && \
    unzip instantclient-basiclite-linux.x64-${ORACLE_INSTANT_CLIENT_VERSION}.zip -d /opt/oracle && \
    rm instantclient-basiclite-linux.x64-${ORACLE_INSTANT_CLIENT_VERSION}.zip && \
    ln -s $ORACLE_HOME/libclntsh.so.* $ORACLE_HOME/libclntsh.so

ENV LD_LIBRARY_PATH=$ORACLE_HOME:$LD_LIBRARY_PATH
ENV PATH=$ORACLE_HOME:$PATH

# Set working directory
WORKDIR /opt/etl

# Copy project files
COPY ../ /opt/etl/

# Install Python dependencies
RUN pip install --no-cache-dir pandas sqlalchemy cx_Oracle apache-airflow

# Expose Airflow webserver port
EXPOSE 8080

# Initialize Airflow and start scheduler
CMD ["bash", "-c", "airflow db init && airflow scheduler & airflow webserver"]